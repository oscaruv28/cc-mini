# --- Base de datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cc_mini
DB_USER=cc_mini
DB_PASSWORD=cc_mini

# --- Aplicación ---
PORT=3000
NODE_ENV=development

# Zona horaria de la operación (Colombia, UTC-5).
# Se usa para agrupar métricas "por día" en el motor, no la del servidor.
APP_TZ=America/Bogota
