# --- Base de datos (PostgreSQL) ---
DB_HOST=localhost
# El contenedor Postgres se expone en el host en 5433 (ver docker-compose.yml).
DB_PORT=5433
DB_NAME=cc_mini
DB_USER=cc_mini
DB_PASSWORD=cc_mini

# --- Aplicación ---
PORT=3000
NODE_ENV=development

# Zona horaria de la operación (Colombia, UTC-5).
# Se usa para agrupar métricas "por día" en el motor, no la del servidor.
APP_TZ=America/Bogota

# Secreto para firmar los JWT del login.
JWT_SECRET=dev-secret-change-me
